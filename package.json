{
  "name": "gh-watch",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm --filter ./api dev",
    "dev:app": "pnpm --filter ./app dev",
    "dev:web": "pnpm --filter ./web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter ./api db:push",
    "db:studio": "pnpm --filter ./api db:studio"
  }
}
